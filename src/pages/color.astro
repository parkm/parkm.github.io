---
export const title = "Color";
export const description = "Shifting colors and waves";
export const icon = "🌊";
export const category = "Entertainment";

import Layout from "../layouts/Layout.astro";
---

<Layout title={title} description={description} disableZoom={true}>
  <script is:inline>
    document.documentElement.style.overscrollBehavior = 'none';
  </script>

  <canvas id="pixiCanvas" class="fixed inset-0 w-screen h-screen block"></canvas>
  <canvas id="gemCanvas" class="fixed inset-0 w-screen h-screen block pointer-events-none z-[5]"></canvas>

  <!-- Top bar: menu (left) · hex/stats (center) · play (right). Full width on
       mobile, capped + centered on wide screens so it never spreads too far. -->
  <div class="fixed top-4 inset-x-0 z-20 px-3 pointer-events-none">
    <div class="mx-auto max-w-lg flex items-start justify-between gap-3">
      <button
        id="menuToggle"
        aria-label="Menu"
        class="pointer-events-auto shrink-0 w-9 h-9 rounded-full bg-black/40 backdrop-blur text-white text-base font-semibold border border-white/20 active:scale-95 transition flex items-center justify-center"
      >
        ☰
      </button>

      <div class="flex flex-col items-center gap-0.5 min-w-0 text-center">
        <div id="colorValue" class="text-2xl font-bold text-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.8)] transition-all duration-300">#6B9FFF</div>

        <div id="gameHud" class="hidden flex flex-col items-center gap-1">
          <div id="scoreValue" class="text-3xl font-black text-white drop-shadow-[0_2px_10px_rgba(0,0,0,0.85)] tabular-nums leading-none">0</div>
          <div id="comboWrap" class="flex items-center gap-2 transition-opacity duration-150" style="opacity:0">
            <span id="comboMult" class="text-base font-black drop-shadow-[0_2px_8px_rgba(0,0,0,0.85)] leading-none">×1</span>
            <div class="w-16 h-1 rounded-full bg-black/40 overflow-hidden border border-white/15">
              <div id="comboBar" class="h-full w-0"></div>
            </div>
            <span id="comboCount" class="text-[10px] text-white/60 font-semibold whitespace-nowrap">0 combo</span>
          </div>
          <div class="flex items-center gap-1.5 text-[10px] text-white/50 font-semibold uppercase tracking-wider">
            <span id="phaseLabel">Wave 1</span>
            <span>·</span>
            <span id="bestValue">Best 0</span>
          </div>
        </div>
      </div>

      <button
        id="gameToggle"
        class="pointer-events-auto shrink-0 px-3.5 py-1.5 rounded-full bg-black/40 backdrop-blur text-white text-sm font-semibold border border-white/20 active:scale-95 transition whitespace-nowrap"
      >
        🎮 Play
      </button>
    </div>
  </div>

  <!-- Match guidance: slim, bottom center. -->
  <div
    id="matchHud"
    class="fixed bottom-6 inset-x-0 z-10 px-4 pointer-events-none hidden flex flex-col items-center gap-1.5"
  >
    <div id="gameStatus" class="text-white/90 text-xs font-medium drop-shadow-[0_2px_8px_rgba(0,0,0,0.8)] h-4"></div>
    <div class="flex items-center gap-2">
      <div id="targetSwatch" class="w-6 h-6 rounded-full border-2 border-white/70 shrink-0"></div>
      <div class="w-40 h-1.5 rounded-full bg-black/40 overflow-hidden border border-white/15">
        <div id="matchBar" class="h-full w-0 transition-[width] duration-100"></div>
      </div>
    </div>
  </div>

  <div
    id="menu"
    class="fixed inset-0 z-40 flex items-center justify-center bg-black/60 backdrop-blur-sm hidden"
  >
    <div class="bg-neutral-900/85 border border-white/15 rounded-2xl p-6 flex flex-col items-center gap-4 text-white w-[90%] max-w-xs mx-4">
      <div class="text-lg font-bold">Menu</div>
      <div id="menuMsg" class="text-emerald-300 text-sm text-center h-5"></div>
      <div class="flex flex-col gap-2 w-full">
        <button id="menuResume" class="px-4 py-2 rounded-full bg-sky-500/80 border border-sky-300/40 font-semibold active:scale-95 transition">Resume</button>
        <button id="menuClear" class="px-4 py-2 rounded-full bg-red-500/70 border border-red-300/30 font-semibold active:scale-95 transition">Clear saved progress</button>
      </div>
      <div class="text-white/40 text-xs">Press Esc to close</div>
    </div>
  </div>

  <script>
    import { initWaves } from "@/components/Color/waves";
    import { game } from "@/components/Color/game";
    import { initInput } from "@/components/Color/input";
    import {
      saveProgress,
      clearProgress,
      hasProgress,
    } from "@/components/Color/progress";

    const canvas = document.getElementById("pixiCanvas") as HTMLCanvasElement;
    const colorValue = document.getElementById("colorValue") as HTMLElement;
    const gameToggle = document.getElementById("gameToggle") as HTMLButtonElement;
    const gameHud = document.getElementById("gameHud") as HTMLElement;
    const matchHud = document.getElementById("matchHud") as HTMLElement;

    initWaves(canvas, colorValue);
    game.init();
    initInput();

    // Swap the calm hex readout for the game stats + match strip while playing.
    function showGameUi(on: boolean) {
      gameHud.classList.toggle("hidden", !on);
      matchHud.classList.toggle("hidden", !on);
      colorValue.classList.toggle("hidden", on);
    }

    // ---- progress persistence ----
    let saveTimer = 0;
    function persist() {
      if (!game.active || saveTimer) return;
      saveTimer = window.setTimeout(() => {
        saveTimer = 0;
        saveProgress(game.getSnapshot());
      }, 400);
    }
    function flush() {
      if (saveTimer) {
        clearTimeout(saveTimer);
        saveTimer = 0;
      }
      if (game.active) saveProgress(game.getSnapshot());
    }
    game.onChange = persist;
    window.addEventListener("beforeunload", flush);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) flush();
    });

    const idleLabel = () => (hasProgress() ? "🎮 Continue" : "🎮 Play");

    function stopGame() {
      game.stop();
      showGameUi(false);
      gameToggle.textContent = idleLabel();
    }

    gameToggle.textContent = idleLabel();

    gameToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      if (game.active) {
        flush();
        stopGame();
      } else {
        game.start();
        showGameUi(true);
        gameToggle.textContent = "✕ Stop";
      }
    });

    // ---- Esc menu ----
    const menuEl = document.getElementById("menu") as HTMLElement;
    const menuMsg = document.getElementById("menuMsg") as HTMLElement;
    const menuToggle = document.getElementById("menuToggle") as HTMLButtonElement;
    const menuResume = document.getElementById("menuResume") as HTMLButtonElement;
    const menuClear = document.getElementById("menuClear") as HTMLButtonElement;

    let menuPrevPaused = false;

    function openMenu() {
      menuPrevPaused = game.paused;
      game.paused = true;
      menuMsg.textContent = "";
      menuEl.classList.remove("hidden");
    }
    function closeMenu() {
      menuEl.classList.add("hidden");
      game.paused = menuPrevPaused;
    }
    function toggleMenu() {
      if (menuEl.classList.contains("hidden")) openMenu();
      else closeMenu();
    }

    menuToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleMenu();
    });
    menuResume.addEventListener("click", () => closeMenu());
    menuClear.addEventListener("click", () => {
      game.stop(); // active=false first so nothing re-saves
      if (saveTimer) {
        clearTimeout(saveTimer);
        saveTimer = 0;
      }
      clearProgress();
      showGameUi(false);
      gameToggle.textContent = idleLabel();
      menuPrevPaused = false;
      menuMsg.textContent = "Progress cleared.";
    });

    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        e.preventDefault();
        toggleMenu();
      }
    });
  </script>
</Layout>
