---
export const title = "Site Map";
export const description = "All pages on the site";
export const icon = "🗺️";

import Layout from "src/layouts/Layout.astro";

const modules = import.meta.glob("/src/pages/**/*.astro", { eager: true });

type PageModule = {
  title?: string;
  description?: string;
  icon?: string;
  category?: string;
};

const CATEGORY_ORDER = ["Tools", "Entertainment", "Other"];

const allLinks = [
  ...Object.keys(modules)
    .filter(
      (filePath) =>
        filePath !== "/src/pages/map.astro" &&
        (!/\/index\.astro$/.test(filePath) ||
          filePath === "/src/pages/index.astro")
    )
    .map((filePath) => {
      const module = modules[filePath] as PageModule;
      const href =
        filePath
          .replace("/src/pages", "")
          .replace(/index\.astro$/, "")
          .replace(/\.astro$/, "")
          .replace(/\/$/, "") || "/";
      const isRoot = filePath === "/src/pages/index.astro";

      const fallbackTitle = isRoot
        ? "Root"
        : (filePath
            .split("/")
            .pop()
            ?.replace(".astro", "")
            .replace(/-/g, " ")
            .replace(/\b\w/g, (c) => c.toUpperCase()) ?? "");

      return {
        href,
        title: isRoot ? "Home" : (module.title || fallbackTitle),
        description: isRoot ? undefined : module.description,
        icon: module.icon,
        category: module.category ?? "Other",
        isRoot,
      };
    }),
  {
    href: "/partygif",
    title: "PartyGif",
    description: "Create party gifs client-side",
    icon: "🎉",
    category: "Tools",
    isRoot: false,
  },
];

const grouped = CATEGORY_ORDER.map((cat) => ({
  category: cat,
  links: allLinks
    .filter((l) => !l.isRoot && l.category === cat)
    .toSorted((a, b) => a.title.localeCompare(b.title)),
}));
---

<Layout title={title} description={description}>
  <main class="min-h-screen px-6 pt-1 pb-8 text-white">
    <!-- Background -->
    <div class="pointer-events-none fixed inset-0 -z-10 bg-[#070A12]">
      <div
        class="absolute inset-0 bg-[radial-gradient(1200px_700px_at_20%_10%,rgba(120,119,198,0.28),transparent_55%),radial-gradient(900px_600px_at_80%_20%,rgba(56,189,248,0.20),transparent_60%),radial-gradient(900px_700px_at_50%_90%,rgba(34,211,238,0.14),transparent_60%)]"
      >
      </div>
      <div
        class="absolute inset-0 opacity-[0.10] [background-image:radial-gradient(rgba(255,255,255,0.9)_1px,transparent_1px)] [background-size:22px_22px]"
      >
      </div>
      <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/35"
      >
      </div>
    </div>

    <header class="mx-auto mb-10 max-w-2xl text-center">
      <h1 class="relative mt-5 inline-block text-4xl font-semibold tracking-tight sm:text-5xl">
        Site Map
        <a
          href="/"
          class="absolute top-full left-1/2 mt-2 flex -translate-x-1/2 items-center gap-1.5 rounded-lg border border-white/10 bg-white/[0.05] px-3 py-1.5 text-sm font-medium whitespace-nowrap
                 transition-[background-color,border-color] duration-150
                 hover:border-white/16 hover:bg-white/[0.09]
                 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-300/60"
        >
          <span aria-hidden="true">🏠</span>
          Home
        </a>
      </h1>
    </header>

    <div class="mx-auto max-w-2xl space-y-10">
      {
        grouped.map(({ category, links }) => (
          <section>
            <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-white/40">
              {category}
            </h2>
            <ul class="space-y-1.5">
              {links.map(({ href, title, description, icon }) => (
                <li>
                  <a
                    href={href}
                    class="group flex items-center gap-3 rounded-xl border border-white/10 bg-white/[0.05] px-4 py-2.5
                           transition-[background-color,border-color] duration-150
                           hover:border-white/16 hover:bg-white/[0.09]
                           focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-300/60"
                  >
                    {icon && (
                      <span class="shrink-0 text-xl leading-none" aria-hidden="true">
                        {icon}
                      </span>
                    )}
                    <span class="min-w-0">
                      <span class="block text-sm font-semibold leading-snug">{title}</span>
                      {description && (
                        <span class="mt-1 block truncate text-xs text-white/50 leading-snug" title={description}>
                          {description}
                        </span>
                      )}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </main>
</Layout>
